<?php
// Enable error reporting temporarily for debugging
ini_set('display_errors', 1);
ini_set('display_startup_errors', 1);
error_reporting(E_ALL);

session_start();
include 'db_connect.php';

$error = "";
$toastMessage = "";

// Optional message for verified accounts
if (isset($_GET['message']) && $_GET['message'] === "verified") {
    $toastMessage = "Account verified successfully! You can now log in.";
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {

    $email    = trim($_POST['email']);
    $password = $_POST['password'];

    if (empty($email) || empty($password)) {
        $error = "All fields are required.";
    } else {

        $stmt = $conn->prepare("
            SELECT id, username, password, is_verified 
            FROM users 
            WHERE email = ? 
            LIMIT 1
        ");

        if (!$stmt) {
            die("Prepare failed: " . $conn->error);
        }

        $stmt->bind_param("s", $email);
        $stmt->execute();
        $result = $stmt->get_result();

        if ($result->num_rows === 1) {
            $user = $result->fetch_assoc();

            if (!password_verify($password, $user['password'])) {
                $error = "Invalid email or password.";
            } elseif ($user['is_verified'] == 0) {
                $error = "Please verify your email before logging in.";
            } else {
                // Successful login
                $_SESSION['user_id']  = $user['id'];
                $_SESSION['username'] = $user['username'];

                // Log activity
                $custom_action = 'Login';
                $usertype = 'Admin'; // Hardcoded
                $device = isset($_SERVER['HTTP_USER_AGENT']) ? $_SERVER['HTTP_USER_AGENT'] : 'Unknown';

                $log_stmt = $conn->prepare("INSERT INTO activity_logs (username, usertype, action, device) VALUES (?, ?, ?, ?)");
                if ($log_stmt) {
                    $log_stmt->bind_param("ssss", $_SESSION['username'], $usertype, $custom_action, $device);
                    $log_stmt->execute();
                    $log_stmt->close();
                } else {
                    // Optional: uncomment for debugging
                    // die("Log prepare failed: " . $conn->error);
                }

                header("Location: dashboard.php");
                exit;
            }
        } else {
            $error = "Invalid email or password.";
        }
    }
}
